{
  "Feature_ID": "INTER_GNB_DU_LTM_HANDOVER_UE_CONTEXT_SETUP",
  "Feature_Name": "Inter-gNB-DU L1/L2 Triggered Mobility (LTM) Handover UE Context Setup",
  "Release": "18",
  "3GPP_Reference": {
    "Spec": "TS 38.473",
    "Title": "5G; NG-RAN; F1 Application Protocol (F1AP)",
    "Section": "8.1, 3.1, 3.2"
  },
  "Feature_Description": [
    "The Inter-gNB-DU L1/L2 Triggered Mobility (LTM) Handover procedure involves the gNB-CU preparing and sending an F1AP 'UE CONTEXT SETUP REQUEST' message to a candidate gNB-DU.",
    "The candidate gNB-DU is required to respond with an F1AP 'UE CONTEXT SETUP RESPONSE' message.",
    "This message exchange is handled on the gNB-CU to facilitate the Inter-gNB-DU LTM handover, which is a type of mobility triggered by L1/L2 events.",
    "LTM is defined as L1/L2 Triggered Mobility."
  ],
  "Feature_Objectives": [
    "To establish a UE context and associated data bearers in a candidate gNB-DU for a UE undergoing Inter-gNB-DU LTM handover.",
    "To enable seamless mobility for a UE between gNB-DUs within the same gNB-CU based on L1/L2 triggers."
  ],
  "Design_Details": {
    "Protocol_Layers": [
      "F1AP",
      "RRC",
      "PDCP"
    ],
    "Protocol_Interfaces": [
      "F1"
    ]
  },
  "Feature_Implementation_Steps": [
    "1. The gNB-CU decides to perform an Inter-gNB-DU LTM handover for a UE.",
    "2. The gNB-CU prepares the F1AP 'UE CONTEXT SETUP REQUEST' message.",
    "3. The gNB-CU sends the F1AP 'UE CONTEXT SETUP REQUEST' message to the candidate gNB-DU.",
    "4. The candidate gNB-DU processes the 'UE CONTEXT SETUP REQUEST' message, creates the UE context, and sets up data bearers.",
    "5. The candidate gNB-DU prepares the F1AP 'UE CONTEXT SETUP RESPONSE' message.",
    "6. The candidate gNB-DU sends the F1AP 'UE CONTEXT SETUP RESPONSE' message to the gNB-CU.",
    "7. The gNB-CU handles the 'UE CONTEXT SETUP RESPONSE' message to complete the LTM handover procedure."
  ],
  "Call_Flow": [
    {
      "Message": "UE CONTEXT SETUP REQUEST",
      "Actors": [
        "gNB-CU",
        "candidate gNB-DU"
      ],
      "From": "gNB-CU",
      "To": "candidate gNB-DU"
    },
    {
      "Message": "UE CONTEXT SETUP RESPONSE",
      "Actors": [
        "gNB-CU",
        "candidate gNB-DU"
      ],
      "From": "candidate gNB-DU",
      "To": "gNB-CU"
    }
  ],
  "Procedure_Implementation_Steps": [
    "1. The gNB-CU decides to perform an Inter-gNB-DU LTM handover for a UE.",
    "2. The gNB-CU prepares the F1AP 'UE CONTEXT SETUP REQUEST' message.",
    "3. The gNB-CU sends the F1AP 'UE CONTEXT SETUP REQUEST' message to the candidate gNB-DU.",
    "4. The candidate gNB-DU processes the 'UE CONTEXT SETUP REQUEST' message, creates the UE context, and sets up data bearers.",
    "5. The candidate gNB-DU prepares the F1AP 'UE CONTEXT SETUP RESPONSE' message.",
    "6. The candidate gNB-DU sends the F1AP 'UE CONTEXT SETUP RESPONSE' message to the gNB-CU.",
    "7. The gNB-CU handles the 'UE CONTEXT SETUP RESPONSE' message to complete the LTM handover procedure."
  ],
